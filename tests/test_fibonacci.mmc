# ============================================
# MMC Test: Fibonacci Sequence
# ============================================
# ဖိအားဖြေ အတွက် MMC ဖော်ကွက်

func fibonacci(n)
    if n <= 0
        return 0
    if n == 1
        return 1
    return fibonacci(n - 1) + fibonacci(n - 2)

func fibonacci_iter(n)
    if n <= 0
        return 0
    var a = 0
    var b = 1
    var i = 2
    while i <= n
        var temp = a + b
        a = b
        b = temp
        i = i + 1
    return b

# Print first 15 Fibonacci numbers
println "=== Fibonacci Sequence ==="
println ""

for n in range(0, 15)
    var fib = fibonacci_iter(n)
    print "F(", n, ") = "
    println fib
