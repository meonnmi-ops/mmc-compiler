# -*- coding: utf-8 -*-
# =================================================================
# MMC Code Generator v1.0 - Self-Hosted (Written in MMC Language)
# Phase 3.5: Self-Hosting Transition
#
# This module takes an AST (Abstract Syntax Tree) produced by
# mmc_parser.mmc and generates runnable Python 3 source code.
#
# It replaces mmc_transpiler.py's code generation phase.
# Architecture: AST Node -> Recursive CodeGen -> Python String
#
# IA Native Mapping:
#   'အေအိုင်AI' | 'AI' | 'ia' | 'အိုင်အေ' -> __mmc_ai__
#   Methods: ပြောပါ(say), သင်ယူပါ(learn),
#            စဉ်းစားပါ(think), ဖော်ပြပါ(explain)
#
# Pipeline: mmc_lexer.mmc -> mmc_parser.mmc -> mmc_codegen.mmc
# =================================================================

# =================================================================
# SECTION 1: AST Node Type Definitions
# =================================================================
# These constants define every AST node type the parser can produce.
# The code generator pattern-matches on these to dispatch rendering.

# --- Top-level node types ---
NODE_PROGRAM = "Program"
NODE_MODULE = "Module"

# --- Statement node types ---
NODE_FUNCTION_DEF = "FunctionDef"
NODE_CLASS_DEF = "ClassDef"
NODE_RETURN = "Return"
NODE_DELETE = "Delete"
NODE_ASSIGN = "Assign"
NODE_AUG_ASSIGN = "AugAssign"
NODE_ANN_ASSIGN = "AnnAssign"
NODE_EXPR_STMT = "Expr"
NODE_IF = "If"
NODE_FOR = "For"
NODE_WHILE = "While"
NODE_BREAK = "Break"
NODE_CONTINUE = "Continue"
NODE_PASS = "Pass"
NODE_IMPORT = "Import"
NODE_IMPORT_FROM = "ImportFrom"
NODE_TRY = "Try"
NODE_RAISE = "Raise"
NODE_ASSERT = "Assert"
NODE_GLOBAL = "Global"
NODE_NONLOCAL = "Nonlocal"
NODE_MATCH = "Match"
NODE_WITH = "With"
NODE_YIELD = "Yield"
NODE_YIELD_FROM = "YieldFrom"

# --- Expression node types ---
NODE_CALL = "Call"
NODE_IA_CALL = "IACall"
NODE_BIN_OP = "BinOp"
NODE_UNARY_OP = "UnaryOp"
NODE_BOOL_OP = "BoolOp"
NODE_COMPARE = "Compare"
NODE_NAME = "Name"
NODE_CONSTANT = "Constant"
NODE_ATTRIBUTE = "Attribute"
NODE_SUBSCRIPT = "Subscript"
NODE_LIST = "List"
NODE_DICT = "Dict"
NODE_SET = "Set"
NODE_TUPLE = "Tuple"
NODE_LAMBDA = "Lambda"
NODE_IF_EXPR = "IfExpr"
NODE_STARRED = "Starred"
NODE_SLICE = "Slice"
NODE_LIST_COMP = "ListComp"
NODE_DICT_COMP = "DictComp"
NODE_SET_COMP = "SetComp"
NODE_GENERATOR_EXPR = "GeneratorExpr"
NODE_FORMATTED_VALUE = "FormattedValue"
NODE_JOINED_STR = "JoinedStr"
NODE_FSTRING = "FString"
NODE_WALRUS = "Walrus"

# --- Operator types ---
OP_ADD = "Add"
OP_SUB = "Sub"
OP_MULT = "Mult"
OP_DIV = "Div"
OP_FLOOR_DIV = "FloorDiv"
OP_MOD = "Mod"
OP_POW = "Pow"
OP_LSHIFT = "LShift"
OP_RSHIFT = "RShift"
OP_BIT_OR = "BitOr"
OP_BIT_XOR = "BitXor"
OP_BIT_AND = "BitAnd"
OP_MAT_MULT = "MatMult"
OP_AND = "And"
OP_OR = "Or"
OP_NOT = "Not"
OP_INVERT = "Invert"
OP_UADD = "UAdd"
OP_USUB = "USub"
OP_EQ = "Eq"
OP_NOT_EQ = "NotEq"
OP_LT = "Lt"
OP_LT_E = "LtE"
OP_GT = "Gt"
OP_GT_E = "GtE"
OP_IS = "Is"
OP_IS_NOT = "IsNot"
OP_IN = "In"
OP_NOT_IN = "NotIn"

# --- Argument node ---
NODE_ARGUMENT = "arg"
NODE_KEYWORD_ARG = "keyword"

# --- Decorator ---
NODE_DECORATOR = "decorator"

