    OP_BIT_OR: "|",
    OP_BIT_XOR: "^",
    OP_BIT_AND: "&",
    OP_MAT_MULT: "@",
}

UNARY_OP_SYMBOLS = {
    OP_NOT: "not ",
    OP_INVERT: "~",
    OP_UADD: "+",
    OP_USUB: "-",
}

COMPARE_OP_SYMBOLS = {
    OP_EQ: "==",
    OP_NOT_EQ: "!=",
    OP_LT: "<",
    OP_LT_E: "<=",
    OP_GT: ">",
    OP_GT_E: ">=",
    OP_IS: "is",
    OP_IS_NOT: "is not",
    OP_IN: "in",
    OP_NOT_IN: "not in",
}

