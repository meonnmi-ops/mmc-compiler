}

# Variable declaration prefixes (to skip in parser)
SKIP_PREFIXES = {"ကိန်း", "အတည်", "နေရာ", "var", "let", "const"}

# IA keyword variants (token type "IA")
IA_KEYWORDS = {"အေအိုင်AI", "AI", "ia", "အိုင်အေ"}

# IA method mapping
