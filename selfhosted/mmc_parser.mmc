    "dict": "dict", "set": "set", "tuple": "tuple", "range": "range",
    "abs": "abs", "max": "max", "min": "min", "sum": "sum",
    "sorted": "sorted", "map": "map", "filter": "filter",
    "enumerate": "enumerate", "zip": "zip", "round": "round",
    "chr": "chr", "ord": "ord", "open": "open", "input": "input",
    "isinstance": "isinstance", "super": "super", "next": "next",
