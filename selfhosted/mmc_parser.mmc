# -*- coding: utf-8 -*-
# =================================================================
# MMC Parser v1.0 - Self-Hosted (Written in MMC Language)
# Phase 3.6: Self-Hosting Transition
#
# Parses token stream from mmc_lexer.mmc into an Abstract Syntax Tree (AST).
# AST format matches mmc_codegen.mmc data contract exactly.
#
# AST Node Format (dict):
#   {"type": str, ...node-specific fields...}
#
# Data Contract with mmc_codegen.mmc:
#   Every node has a "type" field matching codegen NODE_* constants.
#   Field names match codegen handler expectations exactly.
#
# Pipeline: mmc_lexer.mmc -> mmc_parser.mmc -> mmc_codegen.mmc
# =================================================================

# =================================================================
# SECTION 1: AST Node Type Constants (must match mmc_codegen.mmc)
# =================================================================

# --- Top-level ---
NODE_PROGRAM = "Program"

# --- Statement nodes ---
NODE_FUNCTION_DEF = "FunctionDef"
NODE_CLASS_DEF = "ClassDef"
NODE_RETURN = "Return"
NODE_DELETE = "Delete"
NODE_ASSIGN = "Assign"
NODE_AUG_ASSIGN = "AugAssign"
NODE_ANN_ASSIGN = "AnnAssign"
NODE_EXPR_STMT = "Expr"
NODE_IF = "If"
NODE_FOR = "For"
NODE_WHILE = "While"
NODE_BREAK = "Break"
NODE_CONTINUE = "Continue"
NODE_PASS = "Pass"
NODE_IMPORT = "Import"
NODE_IMPORT_FROM = "ImportFrom"
NODE_TRY = "Try"
NODE_RAISE = "Raise"
NODE_ASSERT = "Assert"
NODE_GLOBAL = "Global"
NODE_NONLOCAL = "Nonlocal"
NODE_MATCH = "Match"
NODE_WITH = "With"
NODE_YIELD = "Yield"
NODE_YIELD_FROM = "YieldFrom"

# --- Expression nodes ---
NODE_CALL = "Call"
NODE_IA_CALL = "IACall"
NODE_BIN_OP = "BinOp"
NODE_UNARY_OP = "UnaryOp"
NODE_BOOL_OP = "BoolOp"
NODE_COMPARE = "Compare"
NODE_NAME = "Name"
NODE_CONSTANT = "Constant"
NODE_ATTRIBUTE = "Attribute"
NODE_SUBSCRIPT = "Subscript"
NODE_LIST = "List"
NODE_DICT = "Dict"
NODE_SET = "Set"
NODE_TUPLE = "Tuple"
NODE_LAMBDA = "Lambda"
NODE_IF_EXPR = "IfExpr"
NODE_STARRED = "Starred"
NODE_SLICE = "Slice"
NODE_LIST_COMP = "ListComp"
NODE_DICT_COMP = "DictComp"
NODE_SET_COMP = "SetComp"
NODE_GENERATOR_EXPR = "GeneratorExpr"
NODE_FORMATTED_VALUE = "FormattedValue"
NODE_JOINED_STR = "JoinedStr"
NODE_FSTRING = "FString"
NODE_WALRUS = "Walrus"


# =================================================================
# SECTION 2: Operator Constants (must match mmc_codegen.mmc)
# =================================================================

OP_ADD = "Add"
OP_SUB = "Sub"
OP_MULT = "Mult"
OP_DIV = "Div"
OP_FLOOR_DIV = "FloorDiv"
OP_MOD = "Mod"
OP_POW = "Pow"
OP_LSHIFT = "LShift"
OP_RSHIFT = "RShift"
OP_BIT_OR = "BitOr"
OP_BIT_XOR = "BitXor"
OP_BIT_AND = "BitAnd"
OP_MAT_MULT = "MatMult"
OP_AND = "And"
OP_OR = "Or"
OP_NOT = "Not"
OP_INVERT = "Invert"
OP_UADD = "UAdd"
OP_USUB = "USub"
OP_EQ = "Eq"
OP_NOT_EQ = "NotEq"
OP_LT = "Lt"
OP_LT_E = "LtE"
OP_GT = "Gt"
OP_GT_E = "GtE"
OP_IS = "Is"
OP_IS_NOT = "IsNot"
OP_IN = "In"
OP_NOT_IN = "NotIn"


# =================================================================
# SECTION 3: Keyword Translation Tables
# =================================================================

# Token value -> Python keyword (used for recognition in parser)
STMT_MAP = {
    "if": "if", "else": "else", "elif": "elif",
    "for": "for", "while": "while", "break": "break",
    "continue": "continue", "def": "def", "return": "return",
    "class": "class", "import": "import", "from": "from",
    "try": "try", "except": "except", "finally": "finally",
    "raise": "raise", "async": "async", "await": "await",
    "and": "and", "or": "or", "not": "not",
    "as": "as", "yield": "yield", "lambda": "lambda",
    "with": "with", "assert": "assert", "pass": "pass",
    "global": "global", "nonlocal": "nonlocal", "del": "del",
    "match": "match", "case": "case",
    # Myanmar variants
    "အကယ်၍": "if", "မဟုတ်ပါက": "else", "မဟုတ်လျှင်": "elif",
    "အတွက်": "for", "လုပ်နေစဉ်": "while", "ရပ်": "break",
    "ဆက်လုပ်": "continue", "အဓိပ္ပာယ်": "def", "ပြန်ပေး": "return",
    "အတန်း": "class", "တင်သွင်း": "import", "မှ": "from",
    "ကြိုးစား": "try", "ဖမ်းမိ": "except", "နောက်ဆုံး": "finally",
    "ချမြှောက်": "raise", "မတူညီ": "async", "မျှော်": "await",
    "ညီမျှလျှင်": "and", "သို့မဟုတ်": "or", "မဟုတ်": "not",
    "အဖြစ်": "as", "ပေး": "yield", "များလိုက်": "lambda",
    "နုတ်ထုတ်": "with", "စာသေးခံ": "assert",
    "ကျန်ရမ်း": "pass", "ကြွင်းလဲ": "global", "ဒေသခံ": "nonlocal",
    "ဖျက်ပါ": "del",
}

VALUE_MAP = {
    "True": "True", "False": "False", "None": "None",
    "self": "self", "cls": "cls",
    "မှန်": "True", "မှား": "False", "ဘာမှမရှိ": "None",
    "ဗလာ": "None", "ဒီ": "self", "ဒါ": "cls",
}

FUNC_MAP = {
    "print": "print", "len": "len", "type": "type", "str": "str",
