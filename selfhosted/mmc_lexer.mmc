# Variable declaration prefixes (skipped in output)
SKIP_KEYWORDS = {"ကိန်း", "အတည်", "နေရာ", "var", "let", "const"}

# IA keyword variants - all map to TOK_IA
IA_KEYWORD_VARIANTS = ["အေအိုင်AI", "AI", "ia", "အိုင်အေ"]

