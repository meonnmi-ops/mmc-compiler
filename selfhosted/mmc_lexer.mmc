# -*- coding: utf-8 -*-
# =================================================================
# MMC Lexer v1.0 - Self-Hosted (Written in MMC Language)
# Phase 3.6: Self-Hosting Transition
#
# Tokenizes MMC source code into a stream of Token objects.
# Output format is compatible with mmc_parser.mmc input.
#
# Token Format:
#   {"type": str, "value": str, "line": int, "col": int}
#
# IA Keyword Variants (all map to token type "IA"):
#   'အေအိုင်AI', 'AI', 'ia', 'အိုင်အေ'
#
# Myanmar Digit Pipeline:
#   '၁၂၃' -> Token(type=NUMBER, value='၁၂၃') -> Parser -> '123'
#
# Pipeline: mmc_lexer.mmc -> mmc_parser.mmc -> mmc_codegen.mmc
# =================================================================

# =================================================================
# SECTION 1: Token Type Constants
# =================================================================

TOK_WORD = "WORD"          # Identifiers, keywords (Myanmar & English)
TOK_NUMBER = "NUMBER"      # Integer and float literals (including Myanmar digits)
TOK_STRING = "STRING"      # String literals (single, double, triple-quoted)
TOK_FSTRING = "FSTRING"    # f-string literals
TOK_OP = "OP"              # Operators and punctuation
TOK_NEWLINE = "NEWLINE"    # Line breaks
TOK_COMMENT = "COMMENT"    # Python-style # comments
TOK_INDENT = "INDENT"      # Indentation marker
TOK_DEDENT = "DEDENT"      # Dedentation marker
TOK_EOF = "EOF"            # End of file
TOK_IA = "IA"              # IA keyword (any of the 4 variants)
TOK_UNKNOWN = "UNKNOWN"    # Unrecognized characters


# =================================================================
# SECTION 2: Myanmar Keyword Tables
# =================================================================

