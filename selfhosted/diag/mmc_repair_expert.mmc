# လုံးဝ ဖုန်းတို့မှာ ဒီ power rail ၁၀ ခု စုစုပေါင်း ပါဝင်ပါတယ်။
# VCC_MAIN = မူရင်းအားနည်းချိန်, VDD_MEM = မြန်မာဘာသာစကား
# VDD_CPU = စနစ်ဖြန်းလမ်း, VDD_IO = ချိတ်ဆက်ရေး

device_rails = [
    ["VCC_MAIN", "VDD_MEM", "VDD_CPU", "VDD_IO", "VDD_LCD",
     "VDD_USB", "VDD_WIFI", "VDD_AUD", "VDD_SIM", "VDD_VIBRA"],
    ["VCC_MAIN", "VDD_MEM", "VDD_CPU", "VDD_IO", "VDD_LCD",
     "VDD_USB", "VDD_WIFI", "VDD_AUD", "VDD_SIM", "VDD_VIBRA"],
    ["VCC_MAIN", "VDD_MEM", "VDD_CPU", "VDD_IO", "VDD_LCD",
     "VDD_USB", "VDD_WIFI", "VDD_AUD", "VDD_SIM", "VDD_VIBRA"]
