# -*- coding: utf-8 -*-
# =================================================================
# MMC Hardware Diagnostic Suite — Phase 5 Expert Diagnostic Logic
# mmc_repair_expert.mmc
#
# Professional-grade expert diagnostic module targeting
# Qualcomm Snapdragon 4 Gen 2 (ARM64) for HyperOS/Android phones.
# Covers Redmi Note 12R, Xiaomi 13, POCO X5 Pro fault patterns.
#
# Features:
#   - Expert voltage rail analysis with adaptive thresholds
#   - Short-circuit detection with confidence scoring
#   - Recursive half-split isolation technique
#   - Comprehensive Xiaomi device fault database
#   - Snapdragon 4 Gen 2 specific reference data
#   - Temperature monitoring and thermal protection
#   - AI-powered repair report generation
#
# Pipeline: mmc_lexer.mmc -> mmc_parser.mmc -> mmc_c_codegen.mmc -> C99
# Target: GCC cross-compilation for ARM-v8 (mobile processors)
#
# IA Context: AI-Assisted Hardware Diagnostics
# GitHub: meonnmi-ops/mmc-compiler
# =================================================================

# =================================================================
# SECTION 1: Severity Constants
# ထိပ်တန်းအဆင့်များ — အရေးကြီးဆုံးအချက်အလက်များနှင့် အဓိရဘူးလို့
# စစ်ဆေးတဲ့ အဆင့်များဖြစ်ပါတယ်။
# =================================================================

SEVERITY_CRITICAL = 4
SEVERITY_HIGH = 3
SEVERITY_MEDIUM = 2
SEVERITY_LOW = 1
SEVERITY_INFO = 0

# =================================================================
# SECTION 2: Device Database — Redmi/Xiaomi Fault Patterns
# ခွဲခြမ်းစိတ်ဖြာ ဒေတာဘော compress ပြုလုပ်ထားတဲ့
# စက်ရုံသုံး ဖုန်းများရဲ့ ပြဿနာအကျုံးဝင်များဖြစ်ပါတယ်။
# =================================================================

# --- ထုတ်လုပ်ဖုန်းအမည်များကို အမှတ်အသားထားသည့် အိတ်ဝင် ---
# ဤ ဒေတာတွင် အဓိက စမ်းသပ်မှုလုပ်တဲ့ ဖုန်း ၃ မျိုးပါဝင်ပါတယ်။
# Redmi Note 12R ၊ Xiaomi 13 ၊ POCO X5 Pro တို့ဖြစ်ပါတယ်။

