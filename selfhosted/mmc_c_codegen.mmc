# MMC C Code Generator v1.0 - Self-Hosted (Written in MMC Language)
# Phase 4: Native C Backend
#
# Converts AST to compilable C99 source code.
# Links with ia_bridge.c for IA support.
# Compatible with GCC/Clang for cross-platform (Mobile/PC) support.
#
# IA Context: အေအိုင်AI — Nyanlin-AI
# Pipeline: mmc_lexer.mmc -> mmc_parser.mmc -> mmc_c_codegen.mmc -> C99

# =================================================================
# SECTION 1: C Operator Symbol Tables
# =================================================================
# Maps AST operator names to their C language equivalents.
# These differ from the Python tables in key ways:
#   - "not"  -> "!"   (not "not ")
#   - "and"  -> "&&"  (not "and")
#   - "or"   -> "||"  (not "or")
#   - "Pow"  -> "pow(" (C math library function)
#   - "FloorDiv" -> "/" with cast (C integer division)

BIN_OP_SYMBOLS_C = {
    "Add": "+",
    "Sub": "-",
    "Mult": "*",
    "Div": "/",
    "Mod": "%",
    "Pow": "pow(",
    "FloorDiv": "/",
    "BitOr": "|",
    "BitXor": "^",
    "BitAnd": "&",
    "LShift": "<<",
    "RShift": ">>",
    "MatMult": "*",
}

UNARY_OP_SYMBOLS_C = {
    "Not": "!",
    "Invert": "~",
    "UAdd": "+",
    "USub": "-",
}

COMPARE_OP_SYMBOLS_C = {
    "Eq": "==",
    "NotEq": "!=",
    "Lt": "<",
    "LtE": "<=",
    "Gt": ">",
    "GtE": ">=",
    "Is": "==",
    "IsNot": "!=",
    "And": "&&",
    "Or": "||",
}

# =================================================================
# SECTION 2: Node Type Constants (mirrors mmc_codegen.mmc)
# =================================================================

NODE_PROGRAM = "Program"
NODE_MODULE = "Module"
NODE_FUNCTION_DEF = "FunctionDef"
NODE_RETURN = "Return"
NODE_ASSIGN = "Assign"
NODE_AUG_ASSIGN = "AugAssign"
NODE_ANN_ASSIGN = "AnnAssign"
NODE_IF = "If"
NODE_FOR = "For"
NODE_WHILE = "While"
NODE_BREAK = "Break"
NODE_CONTINUE = "Continue"
NODE_PASS = "Pass"
NODE_EXPR_STMT = "Expr"
NODE_CALL = "Call"
NODE_IA_CALL = "IACall"
NODE_BIN_OP = "BinOp"
NODE_UNARY_OP = "UnaryOp"
NODE_BOOL_OP = "BoolOp"
NODE_COMPARE = "Compare"
NODE_NAME = "Name"
NODE_CONSTANT = "Constant"
NODE_ATTRIBUTE = "Attribute"
NODE_SUBSCRIPT = "Subscript"
NODE_LIST = "List"
NODE_DICT = "Dict"
NODE_SET = "Set"
NODE_TUPLE = "Tuple"
NODE_FSTRING = "FString"
NODE_JOINED_STR = "JoinedStr"

# =================================================================
