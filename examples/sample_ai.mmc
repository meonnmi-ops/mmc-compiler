# AI Inference Example in MMC
# AI မေးမြန်းခြင်း နမူနာ

အဓိပ္ပာယ် main() {
    # Load AI model
    model = AIစရင်း("gemma-1b.gguf");
    
    # Ask question
    question = "မင်္ဂလာပါ ဘယ်နှစ်ရက်ရှိပြီလဲ";
    result = AIမေး(model, question);
    
    # Print result
    ပုံနှိပ်("AI Response:");
    ပုံနှိပ်(result);
    
    ပြန်ပေး 0;
}
